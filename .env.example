# =============================================================================
# Nevada Inventory System — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and adjust the values for your environment.
# 
# Variables prefixed with NEXT_PUBLIC_ are exposed to the browser and should
# NOT contain sensitive information like API keys or passwords.
# =============================================================================

# --- Application Configuration ---

# App URL (used for metadata, absolute URLs, and redirects)
# Used in: Open Graph tags, canonical URLs, email links
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App display name (shown in UI, browser title, emails)
NEXT_PUBLIC_APP_NAME=Nevada Inventory System

# --- API Configuration ---

# Backend API base URL
# Used for all HTTP requests to the inventory API
# Examples:
#   - http://localhost:8080 (local development)
#   - https://api.staging.example.com (staging)
#   - https://api.example.com (production)
NEXT_PUBLIC_API_URL=http://localhost:8080

# API request timeout in milliseconds
# Controls how long to wait before timing out API requests
# Default: 30000 (30 seconds)
NEXT_PUBLIC_API_TIMEOUT=30000

# --- Authentication Configuration ---

# Cookie name for storing auth tokens
# Must match backend cookie name configuration
NEXT_PUBLIC_AUTH_COOKIE_NAME=nevada_auth_token

# Cookie name for storing refresh tokens
# Used for token rotation and session management
NEXT_PUBLIC_REFRESH_COOKIE_NAME=nevada_refresh_token

# --- Development & Testing ---

# Enable mock API adapter (for development without backend)
# When true: uses in-memory mocks instead of real API calls
# When false: makes actual HTTP requests to NEXT_PUBLIC_API_URL
# Default: false
NEXT_PUBLIC_ENABLE_MOCK_API=false

# --- Monitoring & Error Tracking ---

# Sentry DSN (Data Source Name) for error tracking
# Leave empty to disable Sentry error reporting
# Get your DSN from: https://sentry.io/
# Free tier includes 5,000 events/month
# Examples:
#   - https://examplePublicKey@o0.ingest.sentry.io/0 (production)
#   - (empty for local development)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token (for source map uploads at build time)
# Only needed if you want to upload source maps to Sentry for better error tracking
# Leave empty if not using Sentry
# Get token from: https://sentry.io/settings/account/auth-tokens/
SENTRY_AUTH_TOKEN=

# =============================================================================
# QUICK START GUIDE
# =============================================================================
#
# 1. Development (with local backend):
#    cp .env.example .env.local
#    npm run dev
#    # Keep defaults, just ensure NEXT_PUBLIC_API_URL points to your backend
#
# 2. Development (without backend / using mocks):
#    cp .env.example .env.local
#    # Set: NEXT_PUBLIC_ENABLE_MOCK_API=true
#    npm run dev
#
# 3. Production:
#    cp .env.example .env.local
#    # Update all URLs to production domains
#    # Add SENTRY_AUTH_TOKEN for error tracking
#    # Add NEXT_PUBLIC_SENTRY_DSN for error reporting
#    npm run build && npm start
#
# 4. Testing:
#    NEXT_PUBLIC_ENABLE_MOCK_API=true npm run test
#
# =============================================================================
# NOTES
# =============================================================================
#
# - Never commit .env.local to git (it's in .gitignore)
# - NEXT_PUBLIC_* variables are baked into the bundle at build time
# - To change them after build, you must rebuild
# - Server-side variables (without NEXT_PUBLIC_) can only be read server-side
# - For development, changes to .env.local require restarting the dev server
#
# =============================================================================
