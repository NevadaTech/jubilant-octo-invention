# =============================================================================
# Nevada Inventory System — Frontend Environment Variables
# =============================================================================
# Copy this file to .env.local and adjust the values for your environment.

# App URL (used for metadata and absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App display name
NEXT_PUBLIC_APP_NAME=Nevada Inventory System

# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080

# API request timeout in milliseconds
NEXT_PUBLIC_API_TIMEOUT=30000

# Auth cookie names (must match backend expectations)
NEXT_PUBLIC_AUTH_COOKIE_NAME=nevada_auth_token
NEXT_PUBLIC_REFRESH_COOKIE_NAME=nevada_refresh_token

# Enable mock API (for development without backend)
NEXT_PUBLIC_ENABLE_MOCK_API=false

# Sentry DSN (leave empty to disable — free tier: 5K events/month)
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token (only needed for source map uploads at build time)
SENTRY_AUTH_TOKEN=
